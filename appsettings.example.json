{
  "Logging": {
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff 'UTC' ",
        "UseUtcTimestamp": true,
        "SingleLine": true
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Collector": {
    "ServerId": "YOUR_SERVER_ID",
    "Postgres": {
      "ConnectionString": "Host=YOUR_PG_HOST;Port=5432;Username=YOUR_PG_USER;Password=YOUR_PG_PASSWORD;SslMode=Require;Maximum Pool Size=10;Application Name=dms_metrics_collector",
      "ApplicationDatabases": [
        "YourAppDatabase1",
        "YourAppDatabase2"
      ],
      "AzureSysDatabase": "azure_sys",
      "StatementTimeoutSeconds": 10,
      "LockTimeoutSeconds": 1,
      "IdleInTransactionTimeoutSeconds": 15
    },
    "PgBouncer": {
      "Enabled": false,
      "ConnectionString": "Host=YOUR_PG_HOST;Port=6432;Database=pgbouncer;Username=YOUR_PG_USER;Password=YOUR_PG_PASSWORD;SslMode=Require;Server Compatibility Mode=NoTypeLoading;No Reset On Close=true;Maximum Pool Size=1;Application Name=dms_metrics_collector_pgbouncer"
    },
    "Consolidation": {
      "ConnectionString": "Host=YOUR_CONSOLIDATION_HOST;Port=5432;Database=YOUR_CONSOLIDATION_DB;Username=YOUR_PG_USER;Password=YOUR_PG_PASSWORD;SslMode=Require;Maximum Pool Size=10;Application Name=dms_metrics_consolidation",
      "LocalBufferPath": "d:\\dms-metrics\\buffer"
    },
    "Intervals": {
      "Fast": "00:00:15",
      "Counter30": "00:00:30",
      "Counter60": "00:01:00",
      "Health5m": "00:05:00",
      "Object15m": "00:15:00",
      "Config6h": "06:00:00"
    }
  }
}
